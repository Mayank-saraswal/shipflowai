# ============================================================
# ShipFlow AI — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Database (Postgres + pgvector) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/shipflow_dev

# --- BetterAuth ---
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-here
BETTER_AUTH_URL=http://localhost:8000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# --- GitHub OAuth (for BetterAuth social login) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Mem0 (Cloud) ---
MEM0_API_KEY=

# --- OpenAI (for Vercel AI SDK) ---
OPENAI_API_KEY=

# --- Inngest ---
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# --- Redis (Upstash in prod, local in dev) ---
REDIS_URL=redis://localhost:6379

# --- API Server ---
PORT=8000
NODE_ENV=development
BASE_URL=http://localhost:8000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
